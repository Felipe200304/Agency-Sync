# ============================================================
# Variáveis de ambiente do backend (Agency Sync API)
# Copie para .env e preencha. NÃO comite o .env real (contém segredos).
# Obs.: o Spring Boot não lê .env sozinho — use no docker-compose (env_file),
# na Run Config do IntelliJ, ou no painel do Railway.
# ============================================================

# --- Banco de dados (obrigatório em produção) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/agencysync
SPRING_DATASOURCE_USERNAME=agencysync
SPRING_DATASOURCE_PASSWORD=agencysync

# --- Segurança ---
# Use um segredo forte com 32+ caracteres em produção.
APP_JWT_SECRET=troque-este-segredo-de-desenvolvimento-com-32+caracteres

# --- HTTP ---
# Em PaaS (Railway) a porta é injetada automaticamente; deixe em branco lá.
PORT=8080
# Origens liberadas no CORS (separadas por vírgula). Em prod, inclua a URL do frontend.
APP_CORS_ORIGINS=http://localhost:3000

# --- E-mail (opcional) ---
# Com APP_MAIL_ENABLED=false os e-mails são apenas LOGADOS (modo dev).
APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@agencysync.local
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
